# Environment Variables for Multimodal AI Studio
# Copy this file to .env and fill in your API keys
# DO NOT commit the .env file with real keys to version control!

# GROQ API KEY
# Get your API key from: https://console.groq.com/keys
# Steps:
#   1. Go to https://console.groq.com/keys
#   2. Sign in with your Groq account (create one if needed)
#   3. Click "Create API Key"
#   4. Copy the key and paste it below
GROQ_API_KEY=your_groq_api_key_here

# HUGGING FACE API TOKEN
# Get your token from: https://huggingface.co/settings/tokens
# Steps:
#   1. Go to https://huggingface.co/settings/tokens
#   2. Click "New token"
#   3. Give it a name (e.g., "Multimodal Studio")
#   4. Select "Read" role
#   5. Copy the token and paste it below
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here

# GOOGLE GEMINI API KEY
# Get your API key from: https://aistudio.google.com/apikey
# Steps:
#   1. Go to https://aistudio.google.com/apikey
#   2. Click "Create API key"
#   3. Select or create a Google Cloud project
#   4. Copy the API key and paste it below
GEMINI_API_KEY=your_gemini_api_key_here
